{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BluePill MIDI Trigger",
  "version": "1.0.0",
  "identifier": "br.com.apidocris.miditrigger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BluePill MIDI Trigger",
        "width": 1180,
        "height": 780,
        "minWidth": 940,
        "minHeight": 620
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "2024 CrisTecnica",
    "category": "Music",
    "shortDescription": "Configurador do BluePill MIDI Trigger",
    "longDescription": "Configurador em tempo real para o BluePill MIDI Trigger — ajuste thresholds, notas MIDI, curva de velocity e anti-retrigger via USB.",
    "linux": {
      "deb": {
        "depends": [],
        "files": {
          "/etc/udev/rules.d/99-bluepill-midi.rules": "linux/99-bluepill-midi.rules"
        }
      },
      "appimage": {
        "bundleMediaFramework": false
      },
      "desktopTemplate": "linux/bluepill-midi-trigger.desktop"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["Portuguese"],
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "perMachine",
        "shortcutName": "BluePill MIDI Trigger",
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true,
        "perMachineInstallMode": true
      },
      "wix": {
        "language": "pt-BR"
      }
    }
  }
}
